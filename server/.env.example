# Self-hosted Postgres (same DB your Supabase migrations target, or a fresh instance after migrate).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/BOAT?schema=public"

PORT=3001
HOST=0.0.0.0

# Comma-separated origins, or leave unset / use * for allow-all in dev
# CORS_ORIGIN=http://localhost:5173

NODE_ENV=development

# --- SACCO Clearing Engine — optional; uses a separate Supabase project from Retail/Hotel/School DB ---
# Apply SQL from repo: clearing/supabase-clearing-schema.sql on the clearing project only.
# CLEARING_SUPABASE_URL=https://your-clearing-project.supabase.co
# CLEARING_SUPABASE_SERVICE_ROLE_KEY=your-clearing-service-role-key
# CLEARING_API_KEY=long-random-secret-for-boat-server-to-boat-server-calls
#
# Supabase Edge Function `clearing-retail-settlement` (operational BOAT project) forwards retail sales here — set secrets:
# BOAT_CLEARING_SERVER_URL=http://your-boat-host:3001   (same as boat-server public URL / internal URL Edge can reach)
# CLEARING_API_KEY=<same value as CLEARING_API_KEY above>

# --- Africa's Talking (SMS) — optional; register at https://account.africastalking.com ---
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=
# AFRICAS_TALKING_SENDER_ID=
# AFRICAS_TALKING_SANDBOX=true

# --- Twilio / Meta (optional; WhatsApp uses Meta or Twilio) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# MESSAGING_PROVIDER_DEFAULT={"sms":["africas-talking","twilio"],"whatsapp":["meta-whatsapp","twilio"]}
