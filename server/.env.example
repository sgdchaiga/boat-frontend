# Self-hosted Postgres (same DB your Supabase migrations target, or a fresh instance after migrate).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/BOAT?schema=public"

PORT=3001
HOST=0.0.0.0

# Comma-separated origins, or leave unset / use * for allow-all in dev
# CORS_ORIGIN=http://localhost:5173

NODE_ENV=development
