# Self-hosted Postgres (same DB your Supabase migrations target, or a fresh instance after migrate).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/BOAT?schema=public"

PORT=3001
HOST=0.0.0.0

# Comma-separated origins, or leave unset / use * for allow-all in dev
# CORS_ORIGIN=http://localhost:5173

NODE_ENV=development

# --- Africa's Talking (SMS) — optional; register at https://account.africastalking.com ---
# AFRICAS_TALKING_USERNAME=sandbox
# AFRICAS_TALKING_API_KEY=
# AFRICAS_TALKING_SENDER_ID=
# AFRICAS_TALKING_SANDBOX=true

# --- Twilio / Meta (optional; WhatsApp uses Meta or Twilio) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# MESSAGING_PROVIDER_DEFAULT={"sms":["africas-talking","twilio"],"whatsapp":["meta-whatsapp","twilio"]}
