# Copy to deploy/sync.env — used by scripts/sync-worker.mjs and the Windows scheduled task.
# Never commit real secrets.

# --- Cloud (hosted Supabase project: owner dashboard / sync_events target) ---
CLOUD_SUPABASE_URL=https://your-project.supabase.co
CLOUD_SERVICE_ROLE_KEY=your-cloud-service-role-key

# --- Local Postgres + Fastify (pick this OR legacy local Supabase below) ---
DATABASE_URL=postgresql://boat:change-me-in-production@127.0.0.1:5432/boat?schema=public

# --- Legacy: on-prem Supabase REST (omit DATABASE_URL to use this) ---
# LOCAL_SUPABASE_URL=http://127.0.0.1:54321
# LOCAL_SERVICE_ROLE_KEY=

# Optional
# SYNC_BATCH_SIZE=50
