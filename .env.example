# Copy to `.env` for local development (Vite reads `VITE_*` at build time).
# Production: set these in your hosting provider (Netlify, Vercel, Azure, etc.).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# online (default) = cloud only. lan = on-site Supabase + optional sync queue to cloud
VITE_DEPLOYMENT_MODE=online

# Same uuid as tenant_settings.cloud_tenant_id on the LAN DB (often same as organizations.id)
VITE_TENANT_ID=

# --- boat-server (`server/`, optional): Postgres + SMS/WhatsApp ---
# Africa's Talking SMS (optional): set in server/.env — AFRICAS_TALKING_USERNAME, AFRICAS_TALKING_API_KEY, AFRICAS_TALKING_SENDER_ID, AFRICAS_TALKING_SANDBOX
# Vite app calls boat-server for Send SMS / WhatsApp. In `vite` dev you can omit this and use the /boat-api proxy (same-origin, no CORS).
# VITE_BOAT_API_URL=http://localhost:3001
# DATABASE_URL=postgresql://user:pass@localhost:5432/postgres
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM_NUMBER=
# TWILIO_WHATSAPP_FROM_NUMBER=
# TWILIO_WEBHOOK_SIGNATURE_URL=https://your-public-host/api/v1/webhooks/twilio
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# META_WEBHOOK_APP_SECRET=
# MESSAGING_PROVIDER_DEFAULT={"whatsapp":["meta-whatsapp","twilio"],"sms":["twilio"]}
# MESSAGING_PROVIDER_ORGS={"00000000-0000-0000-0000-000000000000":{"whatsapp":["twilio"]}}
