# Copy to `.env` for local development (Vite reads `VITE_*` at build time).
# Production: set these in your hosting provider (Netlify, Vercel, Azure, etc.).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# If `vite` dev shows net::ERR_FAILED for `*.supabase.co/functions/v1/...`, set true so Edge Function calls
# go through the dev server proxy (same-origin). Restart `npm run dev` after changing.
# VITE_DEV_PROXY_SUPABASE_FUNCTIONS=true

# online (default) = cloud only. lan = on-site Supabase + optional sync queue to cloud
VITE_DEPLOYMENT_MODE=online

# Same uuid as tenant_settings.cloud_tenant_id / cloud organizations.id (desktop local auth uses this for org id if set)
VITE_TENANT_ID=

# Desktop local build (`npm run build:desktop:local` sets VITE_LOCAL_AUTH): pick business type (default retail if unset/invalid).
# VITE_LOCAL_BUSINESS_TYPE=hotel
# Allowed: hotel | retail | school | sacco | manufacturing | vsla | restaurant | mixed | other

# Optional: PEM public key for offline subscription renewal token verification (Admin -> Subscription renewal).
# Must be the public key that signs RS256 renewal JWTs in your platform backend.
# VITE_SUBSCRIPTION_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# --- Supabase Edge Function `subscription-renewal-token` (not in Vite; set on the Supabase project) ---
# Must pair with VITE_SUBSCRIPTION_TOKEN_PUBLIC_KEY above. Private key = PKCS#8 PEM (not "BEGIN RSA PRIVATE KEY").
#   openssl pkcs8 -topk8 -inform PEM -in rsa-private.pem -outform PEM -nocrypt -out private-pkcs8.pem
#   Or without OpenSSL: npm run subscription-renewal:generate-keys (writes .pem files in project root; gitignored)
# Set secret (Dashboard: Project Settings → Edge Functions → Secrets, name SUBSCRIPTION_RENEWAL_PRIVATE_KEY),
# or from repo root after `npm run supabase -- link --project-ref <ref>`:
#   1) Copy supabase/secrets.local.example.env → supabase/secrets.local.env and paste your key (see comments in the file).
#   2) npm run supabase:secrets:subscription-renewal
# Deploy the function: `npm run supabase:deploy:subscription-renewal-token`

# Retail / hotel / school apps keep using VITE_SUPABASE_URL above. The SACCO clearing ledger lives in a
# dedicated Supabase project; boat-server exposes it when you set CLEARING_* in `server/.env` (see server/.env.example).
# Retail POS → clearing: deploy Edge Function `clearing-retail-settlement`, run migration organizations_clearing_sacco_links,
# set org columns clearing_default_payer_sacco_id + clearing_merchant_sacco_id, then enable:
# VITE_CLEARING_RETAIL_SETTLEMENT=true
# Platform superadmin UI uses Edge Function `clearing-admin-org-activation` (no frontend key required).

# --- boat-server (`server/`, optional): Postgres + SMS/WhatsApp + Clearing Engine ---
# Africa's Talking SMS (optional): set in server/.env — AFRICAS_TALKING_USERNAME, AFRICAS_TALKING_API_KEY, AFRICAS_TALKING_SENDER_ID, AFRICAS_TALKING_SANDBOX
# Vite app calls boat-server for Send SMS / WhatsApp. In `vite` dev you can omit this and use the /boat-api proxy (same-origin, no CORS).
# VITE_BOAT_API_URL=http://localhost:3001
# DATABASE_URL=postgresql://user:pass@localhost:5432/postgres
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM_NUMBER=
# TWILIO_WHATSAPP_FROM_NUMBER=
# TWILIO_WEBHOOK_SIGNATURE_URL=https://your-public-host/api/v1/webhooks/twilio
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# META_WEBHOOK_APP_SECRET=
# MESSAGING_PROVIDER_DEFAULT={"whatsapp":["meta-whatsapp","twilio"],"sms":["twilio"]}
# MESSAGING_PROVIDER_ORGS={"00000000-0000-0000-0000-000000000000":{"whatsapp":["twilio"]}}
